  Insert Into Silver.erp_cust_AZ12(
cid,
bdate,
gen
)



select 
case when cid  like 'NAS%' THEN SUBSTRING(cid,4,len(cid))
else cid
end as cid,
case when bdate > getdate() then null
else bdate
end as bdate,
case when gen = 'F' THEN 'Female'
when gen = 'Female' THEN 'Female'
WHEN gen = 'M' then 'Male'
WHEN gen = 'Male' then 'Male'
else 'n/a'
end as gen
from 
BRONZE.erp_cust_AZ12





-------  Various checking mechanism

  --Removing ids which are more than once
--check nulls or duplicates in primary key

select 
cst_id,
count(*)

from 
bronze.crm_cust_info
group by cst_id
where count(*) > 1;

--check for multiple ids
select * from (

select *,
ROW_NUMBER() over (partition by cst_id order by cst_create_date desc) as flag_last
from bronze.crm_cust_info
)t
where  flag_last = 1;


-- check for emplty spaces
select * from silver.crm_cust_info
where cst_firstname != trim(cst_firstname);

--check for nulls and negative numbers
select 
prd_cost from 
bronze.crm_prd_info
where 
prd_cost is null or prd_cost < 0

-- To check distinct values
select distinct prd_line
from bronze.crm_prd_info

-- check for incorrect dates

select * from bronze.crm_sales_detailes
where  sls_order_date > sls_ship_date or sls_ship_date > sls_due_date

-- cjeck for mistakes in order quantity and sales

select * from 
bronze.crm_sales_detailes
where sls_price*sls_quality !=sls_sales
or sls_price is null or sls_quality is null or sls_sales is null
or sls_price <=0 or sls_quality <=0 or sls_sales <=0

